# ============================================
# Life Coach AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these from: https://app.supabase.com → Your Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# AI API Keys (at least one is required)
# ============================================

# OpenAI Configuration
# Get key from: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Gemini Configuration (alternative to OpenAI)
# Get key from: https://ai.google.dev/
EXPO_PUBLIC_GEMINI_API_KEY=AIza...

# ============================================
# EAS Build Configuration (REQUIRED for builds)
# ============================================
# Get this from: https://expo.dev → Your Project → Project ID
# Or run: eas init (it will show the project ID)
EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================
# App Configuration (optional)
# ============================================
# Enable debug mode for verbose logging
EXPO_PUBLIC_DEBUG_MODE=false
